{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER_NAME;Database=PulseXDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Key": "YOUR_SECRET_KEY_HERE_AT_LEAST_32_CHARACTERS_LONG",
    "Issuer": "PulseXAPI",
    "Audience": "PulseXClient"
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "Username": "your-email@gmail.com",
    "Password": "your-app-password",
    "FromEmail": "your-email@gmail.com",
    "FromName": "PulseX Support"
  },
  "VideoCall": {
    "AppId": "YOUR_AGORA_APP_ID",
    "Secret": "YOUR_AGORA_APP_SECRET",
    "JoinWindowMinutesBefore": 5,
    "DefaultCallDurationMinutes": 30,
    "StunServers": [
      "stun:stun.l.google.com:19302",
      "stun:stun1.l.google.com:19302"
    ],
    "TurnServers": [
      {
        "Urls": "turn:your-turn-server.com:3478",
        "Username": "your-turn-username",
        "Credential": "your-turn-credential"
      }
    ]
  }
}
