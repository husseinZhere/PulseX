# PulseX AI Service — Environment Configuration
# Copy this file to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
DEBUG=False

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760     # 10 MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf

# ── Model Paths ───────────────────────────────────────────────────────────────
MODEL_PATH=./models
USE_GPU=False

# ── CORS Origins (comma-separated) ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Google Gemini AI (optional — enhances chatbot responses) ─────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# If not set, the chatbot uses high-quality template-based responses instead.
GEMINI_API_KEY=

# ── NIH ChestX-ray14 Dataset Path (for cardiac X-ray training) ───────────────
# Point to the directory that contains images/ and Data_Entry_2017.csv
# Default: /data/nih_chest_xray
NIH_XRAY_PATH=/data/nih_chest_xray
